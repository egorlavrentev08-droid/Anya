def call_yandex_gpt(prompt: str) -> str:
    body = {
        "modelUri": f"gpt://{YANDEX_FOLDER_ID}/yandexgpt-lite",
        "completionOptions": {"stream": False, "temperature": 0.8, "maxTokens": 150},
        "messages": [
            {"role": "system", "text": "Ты Аня, милая 19-летняя девушка. Отвечай коротко, с эмодзи, по-русски."},
            {"role": "user", "text": prompt}
        ]
    }
    
    headers = {"Content-Type": "application/json", "Authorization": f"Api-Key {YANDEX_API_KEY}"}
    
    try:response = requests.post(YANDEX_URL, json=body, headers=headers, timeout=10)
        response.raise_for_status()
        result = response.json()
        return result['result']['alternatives'][0]['message']['text'].strip()[:400]
    except Exception as e:
        print(f"YandexGPT ошибка: {e}")
        return None

async def generate_response_with_memory(user_id: int, user_text: str) -> str:
    history = memory.get_recent_history(user_id, days=30)
    
    context = ""
    if history:
        context = "История общения:\n\n"
        for msg, resp, ts in history[-10:]:
            context += f"Парень: {msg}\nАня: {resp}\n\n"
        context += "Продолжи диалог:\n"
    
    prompt = f"{context}Парень: {user_text}\nАня:"
    
    answer = call_yandex_gpt(prompt)
    if not answer:
        answer = random.choice(FALLBACK_RESPONSES)
    
    memory.add_exchange(user_id, user_text, answer)
    return answer

def is_enemy(user_id: int) -> bool:
    return user_id in ENEMY_USER_IDS

def is_love_message(text: str) -> bool:
    love_words = ['люблю', 'обожаю', 'скучаю']
    return any(word in text.lower() for word in love_words)

def is_farm_command(text: str) -> bool:
    return text.lower().strip() in ["аня фарми", "аня, фарми"]

def is_rp_command(text: str) -> bool:
    return any(word in text.lower() for word in ["обнять", "поцеловать"])

