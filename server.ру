class MemorySystem:
    def __init__(self, db_path="anya_memory.db"):
        self.db_path = db_path
        self.init_db()
    
    def init_db(self):
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("""
                CREATE TABLE IF NOT EXISTS conversations (
                    user_id INTEGER,
                    message TEXT,
                    response TEXT,
                    timestamp DATETIME
                )
            """)
    
    def add_exchange(self, user_id: int, user_message: str, bot_response: str):
        with sqlite3.connect(self.db_path) as conn:
            conn.execute(
                "INSERT INTO conversations (user_id, message, response, timestamp) VALUES (?, ?, ?, ?)",
                (user_id, user_message, bot_response, datetime.now())
            )
            month_ago = datetime.now() - timedelta(days=30)
            conn.execute("DELETE FROM conversations WHERE timestamp < ?", (month_ago,))
    
    def get_recent_history(self, user_id: int, days: int = 30) -> List[Tuple]:
        since_date = datetime.now() - timedelta(days=days)
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.execute("""
                SELECT message, response, timestamp 
                FROM conversations 
                WHERE user_id = ? AND timestamp >= ?
                ORDER BY timestamp ASC
                LIMIT 50
            """, (user_id, since_date))
            return cursor.fetchall()
    
    def clear_user_memory(self, user_id: int):
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("DELETE FROM conversations WHERE user_id = ?", (user_id,))
    
    def get_stats(self, user_id: int):
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.execute("SELECT COUNT(*) FROM conversations WHERE user_id = ?", (user_id,))
            return cursor.fetchone()[0]

