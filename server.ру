async def chat(update: Update, context: ContextTypes.DEFAULT_TYPE):
    message = update.message
    user_id = message.from_user.id
    user_text = message.text or ""
    
    if is_enemy(user_id):
        await message.reply_text(random.choice(INSULTS_FOR_ENEMIES))
        return
    
    if not message.text:
        await message.reply_text("Я понимаю только текстовые сообщения 😊")
        return
    
    if message.chat.type != 'private':
        bot_username = context.bot.username.lower()
        if f'@{bot_username}' not in message.text.lower():
            return
    
    if is_farm_command(user_text):
        await message.reply_text("/cookie")
        return
    
    if is_rp_command(user_text):
        if "обнять" in user_text.lower():
            await message.reply_text("*Обнимаю тебя крепко* 🤗")
        elif "поцеловать" in user_text.lower():
            await message.reply_text("*Целую в щёчку* 😳💋")
        return
    
    if is_love_message(user_text):
        await message.reply_text(random.choice(LOVE_RESPONSES))
        return
    
    response = await generate_response_with_memory(user_id, user_text)
    await message.reply_text(response)

async def memory_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    history = memory.get_recent_history(user_id, days=30)
    await update.message.reply_text(f"📝 Я помню {len(history)} твоих сообщений за месяц!")

async def forget_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    memory.clear_user_memory(user_id)
    await update.message.reply_text("Я всё забыла... Начинаем сначала? 😔💔")

async def stats_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    count = memory.get_stats(user_id)
    await update.message.reply_text(f"📊 Я помню {count} твоих сообщений за 30 дней 💾")

def run_bot():
    app = Application.builder().token(TELEGRAM_TOKEN).build()
app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("memory", memory_command))
    app.add_handler(CommandHandler("forget", forget_command))
    app.add_handler(CommandHandler("stats", stats_command))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, chat))
    
    print("Бот Аня запущен!")
    app.run_polling()

