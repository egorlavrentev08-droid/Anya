# ========== ЗАГРУЗКА ПЕРЕМЕННЫХ ОКРУЖЕНИЯ ==========
load_dotenv()

TELEGRAM_TOKEN = os.getenv("TELEGRAM_TOKEN")
YANDEX_API_KEY = os.getenv("YANDEX_API_KEY")
YANDEX_FOLDER_ID = os.getenv("YANDEX_FOLDER_ID")

# Проверка наличия токенов
if not TELEGRAM_TOKEN:
    logging.error("❌ TELEGRAM_TOKEN не найден! Установите переменную окружения")
    sys.exit(1)
if not YANDEX_API_KEY:
    logging.error("❌ YANDEX_API_KEY не найден!")
    sys.exit(1)
if not YANDEX_FOLDER_ID:
    logging.error("❌ YANDEX_FOLDER_ID не найден!")
    sys.exit(1)

# ========== КОНФИГУРАЦИЯ ==========
DB_NAME = "anya_memory.db"
MAX_HISTORY_DAYS = 30
MAX_CONTEXT_MESSAGES = 10

# Чёрный список врагов
ENEMY_USER_IDS = {
    5671873833,
    5377362106,
    5601784321,
    5262124397,
    1718510466,
    5017134390,
    5961277554,
    6240399497,
    6854164790,
    7959620279
}

# Оскорбления для врагов
INSULTS_FOR_ENEMIES = [
    "Твой интеллект конкурирует с камнем. Проигрывает.",
    "Ты как браузер Опера — тормозной и никому не нужный.",
    "Твой отец жалеет, что порвался презерватив.",
    "Ты настолько тупой, что даже отражение не отвечает тебе.",
